{
    "name": "localhoist/laravel",
    "description": "php artisan share — put your local Laravel dev environment online with Vite HMR, Reverb websockets, and signed URLs all working through one tunnel.",
    "license": "MIT",
    "keywords": ["laravel", "tunnel", "share", "ngrok", "vite", "hmr", "reverb", "localhoist"],
    "homepage": "https://localhoist.io",
    "authors": [
        {
            "name": "Lukas Papay",
            "email": "papay.lukas@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/xPapay/localhoist/issues",
        "source": "https://github.com/xPapay/localhoist"
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "symfony/process": "^6.4|^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Localhoist\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Localhoist\\Laravel\\ShareServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
